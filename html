<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>四象限任务管理 · Eisenhower Matrix</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
    background: linear-gradient(135deg, #f5f7fa 0%, #e9eef5 100%);
    min-height: 100vh;
    padding: 24px;
    color: #2c3e50;
  }
  header {
    max-width: 1200px;
    margin: 0 auto 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  header h1 { font-size: 22px; font-weight: 600; }
  header .subtitle { color: #7a869a; font-size: 13px; margin-top: 4px; }
  .clear-btn {
    background: #fff;
    border: 1px solid #dfe3e8;
    color: #5b6b7d;
    padding: 8px 14px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.15s;
  }
  .clear-btn:hover { background: #ffeaea; color: #c0392b; border-color: #f4b6b6; }

  .matrix {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
  }
  .quadrant {
    background: #fff;
    border-radius: 12px;
    padding: 16px;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    border-top: 4px solid var(--accent);
    transition: background 0.15s, transform 0.15s;
  }
  .quadrant.drag-over {
    background: #f0f7ff;
    transform: scale(1.01);
  }
  .q1 { --accent: #e74c3c; }
  .q2 { --accent: #27ae60; }
  .q3 { --accent: #f39c12; }
  .q4 { --accent: #95a5a6; }

  .q-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eef1f5;
  }
  .q-title { font-size: 15px; font-weight: 600; color: var(--accent); }
  .q-tip { font-size: 11px; color: #95a5a6; }
  .q-count {
    font-size: 11px;
    background: #eef1f5;
    color: #5b6b7d;
    padding: 2px 8px;
    border-radius: 10px;
  }

  .add-row {
    display: flex;
    gap: 6px;
    margin-bottom: 10px;
  }
  .add-row input {
    flex: 1;
    padding: 8px 10px;
    border: 1px solid #dfe3e8;
    border-radius: 6px;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s;
  }
  .add-row input:focus { border-color: var(--accent); }
  .add-row button {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0 14px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
  }
  .add-row button:hover { filter: brightness(1.1); }

  .task-list {
    flex: 1;
    list-style: none;
    min-height: 60px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .task-list:empty::after {
    content: "拖拽任务到此，或在上方添加";
    color: #bdc3c7;
    font-size: 12px;
    text-align: center;
    padding: 20px 0;
    border: 2px dashed #eef1f5;
    border-radius: 6px;
  }

  .task {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: #fafbfc;
    border: 1px solid #eef1f5;
    border-radius: 6px;
    cursor: grab;
    transition: all 0.15s;
    user-select: none;
  }
  .task:hover { background: #f3f6fa; border-color: #dfe3e8; }
  .task.dragging { opacity: 0.45; cursor: grabbing; }
  .task input[type="checkbox"] {
    width: 16px; height: 16px;
    cursor: pointer;
    accent-color: var(--accent, #3498db);
  }
  .task .text {
    flex: 1;
    font-size: 13.5px;
    line-height: 1.4;
    word-break: break-word;
  }
  .task.done .text {
    text-decoration: line-through;
    color: #95a5a6;
  }
  .task .del {
    background: none;
    border: none;
    color: #bdc3c7;
    cursor: pointer;
    font-size: 16px;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1;
  }
  .task .del:hover { color: #e74c3c; background: #fff0ee; }
  .task .drag-handle {
    color: #bdc3c7;
    cursor: grab;
    font-size: 13px;
    padding: 0 2px;
  }

  .done-section {
    max-width: 1200px;
    margin: 20px auto 0;
    background: #fff;
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    border-top: 4px solid #8e44ad;
    --accent: #8e44ad;
  }
  .done-section.drag-over { background: #faf5ff; }
  .done-section .q-title { color: #8e44ad; }
  .done-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 40px;
  }
  .done-list:empty::after {
    content: "已完成的任务会出现在这里";
    color: #bdc3c7;
    font-size: 12px;
    text-align: center;
    padding: 16px 0;
    border: 2px dashed #eef1f5;
    border-radius: 6px;
    display: block;
  }
  .done-list .task .origin {
    font-size: 10px;
    background: var(--origin-color, #ecf0f1);
    color: #fff;
    padding: 2px 6px;
    border-radius: 8px;
    font-weight: 500;
  }

  footer {
    max-width: 1200px;
    margin: 20px auto 0;
    text-align: center;
    color: #95a5a6;
    font-size: 11px;
  }

  @media (max-width: 720px) {
    .matrix { grid-template-columns: 1fr; grid-template-rows: auto; }
    .quadrant { min-height: auto; }
  }
</style>
</head>
<body>

<header>
  <div>
    <h1>四象限任务管理</h1>
    <div class="subtitle">Eisenhower Matrix · 按重要性与紧急性组织你的任务</div>
  </div>
  <button class="clear-btn" onclick="clearAll()">清空所有任务</button>
</header>

<div class="matrix">
  <div class="quadrant q1" data-quadrant="q1">
    <div class="q-header">
      <div>
        <div class="q-title">重要 & 紧急</div>
        <div class="q-tip">立即去做 · Do First</div>
      </div>
      <span class="q-count" id="count-q1">0</span>
    </div>
    <div class="add-row">
      <input type="text" placeholder="添加任务..." onkeydown="if(event.key==='Enter')addTask('q1', this)">
      <button onclick="addTask('q1', this.previousElementSibling)">+</button>
    </div>
    <ul class="task-list" id="list-q1"></ul>
  </div>

  <div class="quadrant q2" data-quadrant="q2">
    <div class="q-header">
      <div>
        <div class="q-title">重要 & 不紧急</div>
        <div class="q-tip">计划执行 · Schedule</div>
      </div>
      <span class="q-count" id="count-q2">0</span>
    </div>
    <div class="add-row">
      <input type="text" placeholder="添加任务..." onkeydown="if(event.key==='Enter')addTask('q2', this)">
      <button onclick="addTask('q2', this.previousElementSibling)">+</button>
    </div>
    <ul class="task-list" id="list-q2"></ul>
  </div>

  <div class="quadrant q3" data-quadrant="q3">
    <div class="q-header">
      <div>
        <div class="q-title">紧急 & 不重要</div>
        <div class="q-tip">委派他人 · Delegate</div>
      </div>
      <span class="q-count" id="count-q3">0</span>
    </div>
    <div class="add-row">
      <input type="text" placeholder="添加任务..." onkeydown="if(event.key==='Enter')addTask('q3', this)">
      <button onclick="addTask('q3', this.previousElementSibling)">+</button>
    </div>
    <ul class="task-list" id="list-q3"></ul>
  </div>

  <div class="quadrant q4" data-quadrant="q4">
    <div class="q-header">
      <div>
        <div class="q-title">不重要 & 不紧急</div>
        <div class="q-tip">尽量减少 · Eliminate</div>
      </div>
      <span class="q-count" id="count-q4">0</span>
    </div>
    <div class="add-row">
      <input type="text" placeholder="添加任务..." onkeydown="if(event.key==='Enter')addTask('q4', this)">
      <button onclick="addTask('q4', this.previousElementSibling)">+</button>
    </div>
    <ul class="task-list" id="list-q4"></ul>
  </div>
</div>

<div class="done-section" data-quadrant="done">
  <div class="q-header">
    <div>
      <div class="q-title">已完成</div>
      <div class="q-tip">勾选或拖拽任务到此处标记完成</div>
    </div>
    <span class="q-count" id="count-done">0</span>
  </div>
  <ul class="task-list done-list" id="list-done"></ul>
</div>

<footer>
  提示：勾选完成会把任务归档到下方；取消勾选会把它送回原来的象限。所有数据仅保存在你本地的浏览器里。
</footer>

<script>
  const STORAGE_KEY = 'eisenhower-tasks-v1';
  const Q_LABELS = { q1: '重要·紧急', q2: '重要·不紧急', q3: '紧急·不重要', q4: '不重要·不紧急' };
  const Q_COLORS = { q1: '#e74c3c', q2: '#27ae60', q3: '#f39c12', q4: '#95a5a6' };

  // state: { q1: [...], q2: [...], q3: [...], q4: [...], done: [...] }
  // each task: { id, text, done: bool, origin: 'q1'|... }
  let state = loadState();

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) return JSON.parse(raw);
    } catch (e) {}
    return { q1: [], q2: [], q3: [], q4: [], done: [] };
  }
  function saveState() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
  }

  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
  }

  function addTask(q, input) {
    const text = input.value.trim();
    if (!text) return;
    state[q].push({ id: uid(), text, done: false, origin: q });
    input.value = '';
    render();
  }

  function findTask(id) {
    for (const key of ['q1','q2','q3','q4','done']) {
      const idx = state[key].findIndex(t => t.id === id);
      if (idx !== -1) return { key, idx, task: state[key][idx] };
    }
    return null;
  }

  function toggleDone(id) {
    const found = findTask(id);
    if (!found) return;
    const { key, idx, task } = found;
    state[key].splice(idx, 1);
    task.done = !task.done;
    if (task.done) {
      task.origin = key === 'done' ? task.origin : key;
      state.done.push(task);
    } else {
      const back = task.origin && state[task.origin] ? task.origin : 'q2';
      task.origin = back;
      state[back].push(task);
    }
    render();
  }

  function deleteTask(id) {
    const found = findTask(id);
    if (!found) return;
    state[found.key].splice(found.idx, 1);
    render();
  }

  function moveTask(id, targetQ) {
    const found = findTask(id);
    if (!found) return;
    const { key, idx, task } = found;
    if (key === targetQ) return;
    state[key].splice(idx, 1);
    if (targetQ === 'done') {
      task.done = true;
      task.origin = key === 'done' ? task.origin : key;
    } else {
      task.done = false;
      task.origin = targetQ;
    }
    state[targetQ].push(task);
    render();
  }

  function clearAll() {
    if (!confirm('确定要清空所有任务吗？此操作无法撤销。')) return;
    state = { q1: [], q2: [], q3: [], q4: [], done: [] };
    render();
  }

  function createTaskEl(task, listKey) {
    const li = document.createElement('li');
    li.className = 'task' + (task.done ? ' done' : '');
    li.draggable = true;
    li.dataset.id = task.id;

    const handle = document.createElement('span');
    handle.className = 'drag-handle';
    handle.textContent = '⋮⋮';

    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.checked = task.done;
    cb.addEventListener('change', () => toggleDone(task.id));

    const txt = document.createElement('span');
    txt.className = 'text';
    txt.textContent = task.text;

    li.appendChild(handle);
    li.appendChild(cb);
    li.appendChild(txt);

    if (listKey === 'done' && task.origin && Q_LABELS[task.origin]) {
      const origin = document.createElement('span');
      origin.className = 'origin';
      origin.textContent = Q_LABELS[task.origin];
      origin.style.setProperty('--origin-color', Q_COLORS[task.origin]);
      origin.style.background = Q_COLORS[task.origin];
      li.appendChild(origin);
    }

    const del = document.createElement('button');
    del.className = 'del';
    del.title = '删除';
    del.textContent = '×';
    del.addEventListener('click', () => deleteTask(task.id));
    li.appendChild(del);

    li.addEventListener('dragstart', (e) => {
      li.classList.add('dragging');
      e.dataTransfer.setData('text/plain', task.id);
      e.dataTransfer.effectAllowed = 'move';
    });
    li.addEventListener('dragend', () => li.classList.remove('dragging'));

    return li;
  }

  function render() {
    for (const q of ['q1','q2','q3','q4','done']) {
      const list = document.getElementById('list-' + q);
      list.innerHTML = '';
      for (const task of state[q]) {
        list.appendChild(createTaskEl(task, q));
      }
      const cnt = document.getElementById('count-' + q);
      if (cnt) cnt.textContent = state[q].length;
    }
    saveState();
  }

  // drag-over handling for each drop zone (quadrants + done section)
  document.querySelectorAll('[data-quadrant]').forEach(zone => {
    zone.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      zone.classList.add('drag-over');
    });
    zone.addEventListener('dragleave', (e) => {
      if (!zone.contains(e.relatedTarget)) zone.classList.remove('drag-over');
    });
    zone.addEventListener('drop', (e) => {
      e.preventDefault();
      zone.classList.remove('drag-over');
      const id = e.dataTransfer.getData('text/plain');
      const target = zone.dataset.quadrant;
      if (id && target) moveTask(id, target);
    });
  });

  render();
</script>
</body>
</html>
